{
  "$description": "kon-iro — non-color foundations shared across themes: type, space, radius, motion. Extracted from the ichinichi-ichigo project.",
  "font": {
    "family": {
      "jp":   { "$type": "fontFamily", "$value": ["Shippori Mincho", "serif"], "$description": "明朝 — display + Japanese" },
      "sans": { "$type": "fontFamily", "$value": ["Zen Kaku Gothic New", "system-ui", "sans-serif"], "$description": "ゴシック — UI sans" },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"], "$description": "labels, meta, readings" }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":     { "$type": "fontWeight", "$value": 700 }
    }
  },
  "size": {
    "fluid": {
      "display": { "$type": "dimension", "$value": "clamp(2.5rem, 12vw, 5.5rem)", "$description": "hero word" },
      "h2":      { "$type": "dimension", "$value": "1.5rem" },
      "body":    { "$type": "dimension", "$value": "1.02rem" },
      "label":   { "$type": "dimension", "$value": "0.74rem", "$description": "uppercase mono labels" },
      "meta":    { "$type": "dimension", "$value": "0.72rem" }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0" },
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "5": { "$type": "dimension", "$value": "1.25rem" },
    "6": { "$type": "dimension", "$value": "1.6rem" },
    "8": { "$type": "dimension", "$value": "2rem" },
    "10":{ "$type": "dimension", "$value": "2.4rem" }
  },
  "radius": {
    "sm":     { "$type": "dimension", "$value": "10px", "$description": "focus target" },
    "md":     { "$type": "dimension", "$value": "14px", "$description": "panels / cards" },
    "lg":     { "$type": "dimension", "$value": "26px", "$description": "widget" }
  },
  "measure": {
    "reading": { "$type": "dimension", "$value": "560px", "$description": "max reading width" }
  },
  "motion": {
    "rise":     { "$type": "duration", "$value": "550ms", "$description": "hero rise (translateY + fade)" },
    "fade":     { "$type": "duration", "$value": "400ms" },
    "ease":     { "$type": "cubicBezier", "$value": [0.25, 0.1, 0.25, 1] }
  }
}
